<tool id="tiberius" name="Tiberius" version="@VERSION@+galaxy1" python_template_version="3.5" profile="24.1">
    <description>deep learning-based ab initio gene structure prediction</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <command detect_errors="exit_code"><![CDATA[
    ]]></command>
    <inputs>
        <param argument="--genome" type="data" format="fasta" label="Genome sequence file"/>
        <conditional name="masking">
            <param name="softmasked" type="select" label="Has your genome been soft-masked?" help="It's recommended to use the unmasked models. Some models that were trained on soft-masked genomes are avaialable, but these are only appropriate for finding genes in genomes that were soft-masked in the same way as the training data.">
                <option value="unmasked" selected="true">No</option>
                <option value="softmasked">Yes</option>
            </param>
            <when value="unmasked">
                <param argument="--model" type="select" label="Model">
                    <options from_data_table="tiberius_models">
                        <filter type="static_value" value="unmasked" column="2"/>
                        <filter type="sort_by" column="2" reverse_sort_order="true"/>
                    </options>
                </param>
            </when>
            <when value="softmasked">
                <param argument="--model" type="select" label="Model">
                    <options from_data_table="tiberius_models">
                        <filter type="sort_by" column="2" reverse_sort_order="true"/>
                    </options>
                </param>
            </when>
        </conditional>
    </inputs>
    <outputs>
        <data format="unsorted.bam" name="out_bam" label="Reads from ${on_string} basecalled by ${tool.name} with model ${model.fields.name}" from_work_dir="calls.bam"/>
        <data format="tsv" name="out_tsv" label="${tool.name} sequencing summary for ${on_string}" from_work_dir="summary.tsv"/>
    </outputs>
    <tests>
        <!-- test 1 -->
        <test expect_num_outputs="2">
            <param name="pod5_file" value="FAL00375_473bf0ed_0.ten_reads.pod5"/>
            <param name="model" value="dna_r9.4.1_e8_fast@v3.4"/>
            <param name="trim" value="all"/>
            <output name="out_bam" ftype="unsorted.bam">
                <assert_contents>
                    <has_size size="10000" delta="1000"/>
                </assert_contents>
            </output>
            <output name="out_tsv" ftype="tsv">
                <assert_contents>
                    <has_text text="00777c4b-cbd6-4a79-8647-bbe5f5f3f3bf"/>
                </assert_contents>
            </output>
        </test>
    </tests>
</tool>
