<tool id="tiberius" name="Tiberius" version="@VERSION@+galaxy1" python_template_version="3.5" profile="24.1">
    <description>deep learning-based ab initio gene structure prediction</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <command detect_errors="exit_code"><![CDATA[

exit 1 ;

ln -s '$genome' ./genome.fa &&

tiberius.py
--genome genome.fa
--model "${model.fields.path}"
--out output.gtf
--batch_size '$batch_size'
#if $masking.model.fields.masking_type == 'unmasked'
--no_softmasking
#end if

    ]]></command>
    <inputs>
        <param argument="--genome" type="data" format="fasta" label="Genome sequence file"/>
        <conditional name="masking">
            <param name="softmasked" type="select" label="Has your genome been soft-masked?" help="The Tiberius developers recommend using unmasked models. Some models that were trained on soft-masked genomes are avaialable, but these are only appropriate for finding genes in genomes that were soft-masked in the same way as the training data.">
                <option value="unmasked" selected="true">No</option>
                <option value="softmasked">Yes</option>
            </param>
            <when value="unmasked">
                <param argument="--model" type="select" label="Model">
                    <options from_data_table="tiberius_models">
                        <filter type="static_value" value="unmasked" column="2"/>
                        <filter type="sort_by" column="2" reverse_sort_order="true"/>
                    </options>
                </param>
            </when>
            <when value="softmasked">
                <param argument="--model" type="select" label="Model">
                    <options from_data_table="tiberius_models">
                        <filter type="sort_by" column="2" reverse_sort_order="true"/>
                    </options>
                </param>
            </when>
        </conditional>
        <!-- TODO: set this to hidden, it's just for dev -->
        <param argument="--batch_size" type="integer" value="16"/>
    </inputs>
    <outputs>
        <data format="gtf" name="out_gtf" label="${tool.name} annotation with model ${model.fields.name}" from_work_dir="output.gtf"/>
    </outputs>
    <tests>
        <!-- test 1 -->
        <test expect_num_outputs="1">
            <param name="genome" value="KV860338_truncated.fasta.gz"/>
            <param name="model" value="Vertebrata_unmasked"/>
            <param name="batch_size" value="2"/>
            <output name="out_gtf" ftype="gtf">
                <assert_contents>
                    <has_size size="10000" delta="1000"/>
                </assert_contents>
            </output>
        </test>
        <!-- test 2 -->
        <test expect_num_outputs="1">
            <param name="genome" value="KV860338_truncated.fasta.gz"/>
            <param name="model" value="Mammalia_softmasked"/>
            <param name="batch_size" value="2"/>
            <output name="out_gtf" ftype="gtf">
                <assert_contents>
                    <has_size size="10000" delta="1000"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[

`Tiberius <https://github.com/Gaius-Augustus/Tiberius>`__ is a
deep learning-based ab initio gene structure prediction tool. 
It predicts genes from genomic sequence only.

    ]]></help>
    <expand macro="citation"/>
</tool>
