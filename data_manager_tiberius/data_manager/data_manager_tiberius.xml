<?xml version="1.0"?>
<tool id="data_manager_tiberius" name="Download Tiberius model database" tool_type="manage_data" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>reference data downloader</description>
    <macros>
        <token name="@TOOL_VERSION@">1.1.8</token>
        <token name="@VERSION_SUFFIX@">0</token>
        <token name="@PROFILE@">24.0</token>
    </macros>
    <requirements>
        <requirement type="package" version="3.7">python</requirement>
    </requirements>
    <command detect_errors="exit_code">
        <![CDATA[
        python '$__tool_directory__/data_manager_tiberius.py'
        --out '${out_file}'
        --species '${species_cond.species}'
        --masking '${species_cond.masking_option}'
        ]]>
    </command>
    
    <inputs>
        <conditional name="species_cond">
            <param name="species" type="select" label="Target Species">
                <option value="all">All Species</option>
                <option value="Chlorophyta">Chlorophyta (Green Algae)</option>
                <option value="Bacillariophyta">Bacillariophyta (Diatoms)</option>
                <option value="Eudicotyledons">Eudicotyledons (Eudicots)</option>
                <option value="Fungi">Fungi</option>
                <option value="Insecta">Insecta (Insects)</option>
                <option value="Mammalia">Mammalia (Mammals)</option>
                <option value="Monocotyledonae">Monocotyledonae (Monocots)</option>
                <option value="Vertebrata">Vertebrata (Vertebrates)</option>
            </param>
            
            <when value="all">
                <param name="masking_option" type="select" label="Model Version">
                    <option value="softmasked">Softmasked models only</option>
                    <option value="unmasked">Unmasked models only</option>
                    <option value="both">Both softmasked and unmasked models</option>
                </param>
            </when>
            
            <when value="Chlorophyta">
                <param name="masking_option" type="select" label="Model Version">
                    <option value="unmasked">Unmasked model</option>
                </param>
            </when>
            
            <when value="Bacillariophyta">
                <param name="masking_option" type="select" label="Model Version">
                    <option value="softmasked">Softmasked model</option>
                    <option value="unmasked">Unmasked model</option>
                    <option value="both">Both softmasked and unmasked models</option>
                </param>
            </when>
            
            <when value="Eudicotyledons">
                <param name="masking_option" type="select" label="Model Version">
                    <option value="softmasked">Softmasked model</option>
                </param>
            </when>
            
            <when value="Fungi">
                <param name="masking_option" type="select" label="Model Version">
                    <option value="unmasked">Unmasked model</option>
                </param>
            </when>
            
            <when value="Insecta">
                <param name="masking_option" type="select" label="Model Version">
                    <option value="softmasked">Softmasked model</option>
                    <option value="unmasked">Unmasked model</option>
                    <option value="both">Both softmasked and unmasked models</option>
                </param>
            </when>
            
            <when value="Mammalia">
                <param name="masking_option" type="select" label="Model Version">
                    <option value="softmasked">Softmasked model</option>
                    <option value="unmasked">Unmasked model</option>
                    <option value="both">Both softmasked and unmasked models</option>
                </param>
            </when>
            
            <when value="Monocotyledonae">
                <param name="masking_option" type="select" label="Model Version">
                    <option value="softmasked">Softmasked model</option>
                </param>
            </when>
            
            <when value="Vertebrata">
                <param name="masking_option" type="select" label="Model Version">
                    <option value="unmasked">Unmasked model</option>
                </param>
            </when>
        </conditional>
    </inputs>
    
    <outputs>
        <data name="out_file" format="data_manager_json" />
    </outputs>
    
    <tests>
        <test>
            <conditional name="species_cond">
                <param name="species" value="Chlorophyta"/>
                <param name="masking_option" value="unmasked"/>
            </conditional>
            <output name="out_file" file="Chlorophyta_unmasked.json" compare="sim_size"/>
        </test>
        <test>
            <conditional name="species_cond">
                <param name="species" value="Bacillariophyta"/>
                <param name="masking_option" value="both"/>
            </conditional>
            <output name="out_file" file="Bacillariophyta_both.json" compare="sim_size"/>
        </test>
        <test>
            <conditional name="species_cond">
                <param name="species" value="Insecta"/>
                <param name="masking_option" value="softmasked"/>
            </conditional>
            <output name="out_file" file="Insecta_softmasked.json" compare="sim_size"/>
        </test>
    </tests> 
    <help>

**Tiberius Reference Data Manager**

This data manager downloads and installs Tiberius model weights for mitochondrial gene prediction. Tiberius is a tool for predicting protein-coding genes in mitochondrial genomes using neural network models trained on various taxonomic groups.

**Available Species and Models**

The following species groups are available with their respective model versions:

- Chlorophyta (Green Algae): Unmasked only
- Bacillariophyta (Diatoms): Softmasked and Unmasked
- Eudicotyledons (Eudicots): Softmasked only
- Fungi: Unmasked only
- Insecta (Insects): Softmasked and Unmasked
- Mammalia (Mammals): Softmasked and Unmasked
- Monocotyledonae (Monocots): Softmasked only
- Vertebrata (Vertebrates): Unmasked only

**Model Versions**

- **Softmasked models**: Models trained on softmasked genomic sequences where repetitive regions are masked (converted to lowercase/Ns). These are suitable for genomes with high repeat content.
- **Unmasked models**: Models trained on unmasked genomic sequences where all bases are treated equally. These are suitable for high-quality assemblies with minimal repeats.
- **Both versions**: Downloads both softmasked and unmasked model versions for species where both are available.

**Usage**

1. Select a target species group or "All Species" to download all available models
2. Choose the model version:
   
   - **Softmasked models only**: Downloads only softmasked versions
   - **Unmasked models only**: Downloads only unmasked versions
   - **Both versions**: Downloads both softmasked and unmasked versions (where available)

3. Click "Execute" to download and install the models

**Data Source**

Model weights are downloaded from the Tiberius model repository (see README_ for more information):

.. _README: https://github.com/Gaius-Augustus/Tiberius/blob/main/model_cfg/README.md


    </help>

    <citations>
	    <citation type="doi">10.1093/bioinformatics/btae685</citation>
    </citations>
</tool>

